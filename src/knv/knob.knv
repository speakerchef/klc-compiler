mut totalsteps = 0;
mut n = 1;
while (n < 100000) {
    mut x = n;
    while (x != 1) {
        mut r = x & 1;
        if (r == 1) {
            x = x * 3 + 1;
        } else {
            x = x / 2;
        }
        totalsteps = totalsteps + 1;
    }
    n = n + 1;
}
totalsteps = totalsteps & 255;
exit totalsteps;
